// Prisma schema for Lumen Dental
// LD01a: initial Booking + Service models for the web booking flow.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  pending_confirmation
  confirmed
  cancelled
  completed
  no_response
  conflict
}

model Service {
  id              String    @id @default(cuid())
  name            String
  durationMinutes Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  bookings        Booking[]
}

model Booking {
  id            String        @id @default(cuid())
  serviceId     String
  service       Service       @relation(fields: [serviceId], references: [id])
  patientName   String
  patientEmail  String
  patientPhone  String
  slotStart     DateTime
  status        BookingStatus @default(pending_confirmation)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([slotStart])
  @@index([serviceId])
}
