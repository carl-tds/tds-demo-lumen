# Lumen Dental — environment variable template
# Copy to .env.local for local development (.env.local is git-ignored).
# In production, these are set in the Vercel project settings.

# Postgres connection string for Neon. Format:
#   postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Used by Prisma Client and `prisma migrate deploy`.
DATABASE_URL=
