{
  "$comment": "TDS — Autonomous-with-guardrails permissions. Allows everything routine; explicitly denies destructive operations. Deny rules take priority over allow rules. Adjust per-project as needed.",

  "permissions": {
    "allow": [
      "$comment_file_ops": "Reading anything is fine. Writing is fine inside the repo.",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(*)",
      "Write(*)",

      "$comment_git_safe": "Routine git commands — no force pushes, no destructive resets",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout -b tds/*)",
      "Bash(git checkout tds/*)",
      "Bash(git branch*)",
      "Bash(git push origin tds/*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git stash*)",
      "Bash(git worktree add*)",
      "Bash(git worktree list*)",
      "Bash(git worktree remove ../*-task-*)",

      "$comment_node_safe": "Standard Node tooling — install, test, build, lint",
      "Bash(node *)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npm test*)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(pnpm install*)",
      "Bash(pnpm test*)",
      "Bash(pnpm run *)",
      "Bash(pnpm *)",

      "$comment_python_safe": "Standard Python tooling",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip install *)",
      "Bash(pytest *)",
      "Bash(uv *)",

      "$comment_inspection": "Read-only inspection commands",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find . *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(env)",

      "$comment_repl_dev": "Local dev servers — fine to run",
      "Bash(npm run dev*)",
      "Bash(pnpm dev*)",
      "Bash(npm run build*)",
      "Bash(pnpm build*)",

      "$comment_ghl_scripts": "Running Pathway B scripts in dry-run is fine; --apply is denied below for production",
      "Bash(node scripts/*.ts --dry-run*)",
      "Bash(node scripts/*.js --dry-run*)",
      "Bash(GHL_SUBACCOUNT=*sandbox* node scripts/*)"
    ],

    "deny": [
      "$comment_destructive_filesystem": "Never recursively delete outside the worktree. Never wipe.",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf ..*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf .git*)",
      "Bash(rm -rf node_modules/.cache*)",
      "Bash(sudo *)",
      "Bash(chmod -R *)",
      "Bash(chown *)",

      "$comment_destructive_git": "No force pushes, no history rewrites, no resets that lose work",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git push origin develop*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fdx*)",
      "Bash(git checkout main*)",
      "Bash(git checkout master*)",
      "Bash(git branch -D *)",

      "$comment_secrets": "Never read or write secret files. Repo .gitignore should also enforce this.",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*token*)",
      "Read(**/*secret*)",
      "Read(**/credentials.json)",
      "Read(**/service-account*.json)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",

      "$comment_destructive_db": "Never run destructive DB commands without explicit human ok",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP DATABASE*)",
      "Bash(*TRUNCATE*)",
      "Bash(prisma db push --force-reset*)",
      "Bash(prisma migrate reset*)",

      "$comment_ghl_production": "Pathway B scripts must never hit production subaccount with --apply unless human-approved.",
      "Bash(*GHL_SUBACCOUNT=*main* * --apply*)",
      "Bash(*--apply* *GHL_SUBACCOUNT=*main*)",

      "$comment_npm_destructive": "Never globally install or uninstall things; never publish",
      "Bash(npm install -g*)",
      "Bash(npm uninstall -g*)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Bash(pnpm add -g*)",

      "$comment_network_dangerous": "No arbitrary curl/wget — too easy to exfiltrate data or pull untrusted scripts",
      "Bash(curl *| sh*)",
      "Bash(curl *| bash*)",
      "Bash(wget *| sh*)",
      "Bash(wget *| bash*)"
    ]
  }
}
